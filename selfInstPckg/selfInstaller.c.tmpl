void pathDeleting (char *filename) {
	//
	// Description:
	//	It accepts a filename as argument and remove all its path (eg. local/share/object.txt --> object.txt)
	//
	unsigned int pos = 0;
	unsigned int origLen = strlen(filename);
	
	for (unsigned int x = 0; x < origLen; x++)
		if (filename[x] == '/') pos = x;
	
	if (pos > 0) {
		unsigned int x;
		for (x = 0; x < (origLen - (pos + 1)); x++)
			filename[x] = filename[x + pos + 1];
		filename[x] = '\0';
	}
	
	return;
}

void helpProc (const char *myname, int ec) {
	//
	// Description:
	//	It prints a simple help message
	//
	printf("Use:  %s {--install|--uninstall|--help}\n", myname);
	if (ec != 0) exit(ec);
	return;
}

bool filesGlue (const char *patha, const char *pathb, char *res) {
	//
	// Description:
	//	It allows you to check for the argument defined pats and merge them correctly
	//		(eg. "/etc" + "passwd" ..> "/etc/passwd")
	//
	size_t sizeA = strlen(patha);
	size_t sizeB = strlen(pathb);
	bool   out   = true;

	if (sizeA == 0 || sizeB == 0 || sizeA + sizeB >= PATH_MAX)
		out = false;
	
	else {
		strcpy(res, patha);
		if (res[sizeA-1] != PATH_SPLITTER) {
			res[sizeA]   = '/';
			res[sizeA+1] = '\0';
		}
		strcat(res, pathb);
	}

	return(out);
}

void logMsg (unsigned int line, uint8_t severity, const char *fmt, ...) {
	va_list args;

	va_start(args, fmt);
	if (severity < 16) {
		fprintf(stdout, "%d [i] ", line);
		vfprintf(stdout, fmt, args);
	} else if (severity < 128) {
		fprintf(stdout, "%d [WARNING] ", line);
		vfprintf(stdout, fmt, args);
	} else {
		fprintf(stderr, "%d [ERROR!] ", line);
		vfprintf(stderr, fmt, args);
	}
	va_end(args);
	
	if (severity >= 128)
		exit((int)severity);
}

static la_ssize_t archiveReadCB (struct archive *arch, void *clientData, const void **buffer) {
	//
	// Description:
	//	This is the callback used by the "archive" library to read archived data bytes
	//
	// Arguments:
	//	*arch:       It is a pointer of the archive instance
	//	*clientData  The data access point (FILE*, fd,....)
	//	**buffer     output pointer that will receive the address of the internal buffer containing the newly read bytes
	//
	// Returned value:
	//	>0   Success and the file is not yet finished
	//	0    END of file reached
	//	<0   Error encountered
	//
	static unsigned char readBuffer[READ_BUFFER_SIZE];
	FILE                 *fh  = clientData;
	la_ssize_t           size = 0;

	// Just to avoid the "unused var arch" waring by GCC
	if (arch != NULL) {
		size = (la_ssize_t)fread(readBuffer, 1, sizeof(readBuffer), fh);
		if (size == 0 && ferror(fh)) {
			archive_set_error(arch, errno, "fread() failed");
			size = -1;
		} else
			*buffer = readBuffer;
	}
	
	return(size);
}

static int removeCB (const char *path, const struct stat *sb, int typeflag, struct FTW *ftwbuf) {
	//
	// Description:
	//	This is the CB used by FTW process to remove the dir, recoursively.
	//
	int ec = 0;
	(void)sb;
	(void)ftwbuf;

	if (typeflag == FTW_F || typeflag == FTW_SL || typeflag == FTW_SLN)
		ec = unlink(path);
		
	else if (typeflag == FTW_DP)
		ec = rmdir(path);

	return(ec);
}

int rm_rf(const char *path) {
    return(nftw(path, removeCB, 64, FTW_DEPTH | FTW_PHYS));
}
