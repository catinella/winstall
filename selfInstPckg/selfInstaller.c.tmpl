int main (int argc, char *argv[]) {
	int     option_index = 0;
	int     ec = 0;
	wCmd_t  cmd = _last;
	bool    verboseFlag = false;
	char    pckgFilename[PATH_MAX];

#if BANNER_SIZE == 0
	char banner[BANNER_SIZE];
#else
	char banner[BANNER_SIZE] = BANNER ;
#endif

	struct option optionsPool[] = {
		{"install",   no_argument, NULL, 0},
		{"uninstall", no_argument, NULL, 0},
		{"verbose",   no_argument, NULL, 0},
		{"help",      no_argument, NULL, 0},
		{0, 0, 0, 0}
	};
	
	while (ec == 0) {
		ec = getopt_long (argc, argv, "", optionsPool, &option_index);

		if (ec == 0) {

			//
			// File's arguments collecting
			//
			switch (option_index) {
				case 0: 
					cmd = W_INSTALL;
				break;

				case 1: 
					cmd = W_UNINSTALL;
				break;

				case 3: 
					verboseFlag = false;
				break;

				case 4:
					cmd = W_HELP;
				break;
			}
		}
	}

	if (cmd == _last)
		// ERROR!
		helpProc(argv[0], 127);
	
	else if (cmd == W_HELP)
		helpProc(argv[0], 0);

	// Installed package info-file
	else if (filesGlue(DATALOGFOLDER, PRJNAME, pckgFilename) == false)
		// ERROR!
		LOGMSG(131, "Wrong configured path (DATALOGFOLDER)\n");

	else if (cmd == W_UNINSTALL) {
		struct stat statbuf;

		*pckgFilename = '\0';
		printBanner(banner, BANNER_SIZE);

		// Checking for the DATALOGFOLDER folder
		if (
			stat(DATALOGFOLDER, &statbuf) < 0 ||
			S_ISDIR(statbuf.st_mode)     != 0
		) 
			// ERROR!
			LOGMSG(133, "The \"%s\" folder does not exist or it is not a valid one\n", DATALOGFOLDER);
		
		// Checking for the DATALOGFOLDER/PRJNAME file
		else if (stat(pckgFilename, &statbuf) < 0) {
			// ERROR!
			LOGMSG(32, "The \"%s\" software is not installed\n", PRJNAME);
			exit(32);
			
		} else {
			char file[PATH_MAX];
			FILE *fh = fopen(pckgFilename, "r");
			bool err = false;

			if (fh == NULL)
				// ERROR!
				LOGMSG(135, "I cannot read the \"%s\" file\n", pckgFilename);

			else {
				// Installed files removing
				while (fgets(file, sizeof(file), fh) != NULL) {
					if (unlink(pckgFilename) < 0) {
						LOGMSG(34, "I cannot remove the \"%s\" file\n", file);
						err = true;
						
					} else if (verboseFlag) 
						LOGMSG(1, "\"%s\" removed\n", file);
					
				}

				fclose(fh);
			}
			
			if (err)
				// ERROR!
				LOGMSG(137, "The removing procedure failed! you can find the files-list in the \"%s\" file", pckgFilename);

			// Package info file removing
			else if (unlink(pckgFilename) < 0) 
				// ERROR!
				LOGMSG(137, "I cannot remove the \"%s\" file\n", pckgFilename);

		}

	} else if (cmd == W_INSTALL) {
		struct stat    statbuf;
		FILE           *myselfFH       = NULL;
		struct archive *tgzArch        = NULL;
		unsigned int   elfSize         = 0;
		GPtrArray      *installedFiles = g_ptr_array_new_with_free_func(g_free);

		//
		// Checking for required folders
		//
		{
			if (stat(DATALOGFOLDER, &statbuf) < 0) {
				if (mkdir(DATALOGFOLDER, 755) < 0)
					// ERROR
					LOGMSG(131, "I cannot create the \"%s\" directory\n", DATALOGFOLDER);

				else if (verboseFlag)
					LOGMSG(1, "The \"%s\" directory has been created\n", DATALOGFOLDER);
					
			} else if (S_ISDIR(statbuf.st_mode) == false)
				// ERROR
				LOGMSG(131, "\"%s\" file name is already in use and it is not a directory\n");
		}
		
		// Check for installed files list initialization
		if (installedFiles == NULL) 
			// ERROR
			LOGMSG(131, "Unable to allocate new memory for the installed-files list\n");
			
		// Checking for the DATALOGFOLDER/PRJNAME file
		else if (stat(pckgFilename, &statbuf) == 0) {
			// ERROR!
			LOGMSG(32, "The \"%s\" software is already installed\n", PRJNAME);
			exit(32);
			
		// Get data section offset
		} else if ((elfSize = get_elf_size()) == 0)
			// ERROR!
			LOGMSG(139, "I cannot read my ELF section\n");
		
		// Open myself
		else if ((myselfFH = fopen(MYSELF, "rb")) == NULL)
			// ERROR!
			LOGMSG(141, "I cannot open the \"%s\" file\n", MYSELF);
			
		// Seec for data section
		else if (fseeko(myselfFH, elfSize, SEEK_SET) != 0) {
			// ERROR!
			fclose(myselfFH);
			LOGMSG(143, "seek() failed on the \"/proc/self/exe\" file\n");

		// Change to the root folder
		} else if (chdir("/") != 0) {
			// ERROR!
			fclose(myselfFH);
			LOGMSG(145, "I cannot change my position inside the Filesystem\n");

		// Archive manager creation
		} else if ((tgzArch = archive_read_new()) == NULL) {
			// ERROR!
			fclose(myselfFH);
			LOGMSG(147, "No enough resouces\n");

		// Archive manager cchecking for TGZ format
		} else if (
			archive_read_support_filter_gzip(tgzArch) != ARCHIVE_OK ||
			archive_read_support_format_tar(tgzArch)  != ARCHIVE_OK

		) {
			// ERROR!
			fclose(myselfFH);
			LOGMSG(149, "The internal archiving lib doesn't support the archived data format\n");

		// Callback registration
		} else if (archive_read_open(tgzArch, myselfFH, NULL, archiveReadCB, NULL) != ARCHIVE_OK) {
			// ERROR!
			fclose(myselfFH);
			LOGMSG(151, "Unable to open embedded archive: %s", archive_error_string(tgzArch));

		} else {
			struct archive       *disk    = archive_write_disk_new();
			struct archive_entry *entry   = NULL;
			int                  result   = ARCHIVE_OK;

			archive_write_disk_set_options(
				disk, ARCHIVE_EXTRACT_TIME | ARCHIVE_EXTRACT_PERM | ARCHIVE_EXTRACT_ACL  | ARCHIVE_EXTRACT_FFLAGS
			);

			archive_write_disk_set_standard_lookup(disk);

			//
			// /winstall folder extraction
			//
			while ((result = archive_read_next_header(tgzArch, &entry)) == ARCHIVE_OK) {
				const char *path = archive_entry_pathname(entry);

				if (
					strncmp(path, "winstall/", strlen("winstall/")) == 0 ||
					strcmp(path, "winstall")                        == 0
				) {
					// file extraction
					result = archive_write_header(disk, entry);

					// === SUCCESS ===
					if (result == ARCHIVE_OK || result == ARCHIVE_WARN) {
						const void *data = NULL;
						size_t      size = 0;
						la_int64_t  offset = 0;

						LOGMSG(6, "%s", archive_error_string(disk));
					
						while ((result = archive_read_data_block(tgzArch, &data, &size, &offset)) == ARCHIVE_OK) {

							// Reading file content
							result = archive_write_data_block(disk, data, size, offset);

							if (result != ARCHIVE_OK && result != ARCHIVE_WARN) {
								// ERROR!
								fclose(myselfFH);
								LOGMSG(131, "Unable to extract '%s': %s", path, archive_error_string(disk));
							}
						}

						// Checking for operation's exit-code
						if (archive_write_finish_entry(disk) != ARCHIVE_OK) {
							// ERROR!
							fclose(myselfFH);
							LOGMSG(131, "Unable to complete '%s': %s", path, archive_error_string(disk));
						}
    
					} else {
						// ERROR!
						fclose(myselfFH);
						LOGMSG(131, "Corrupted data\n");
					}
				} else {
					archive_read_data_skip(tgzArch);
					continue;
				}
			}

			if (*PREINST != '\0') {
				struct stat statbuf;
				char        preInstFile[PATH_MAX];

				if (filesGlue("/winstall", PREINST, preInstFile) == false) {
					// ERROR!
					fclose(myselfFH);
					LOGMSG(131, "Configured path or filename is not allowed\n");

				// Check for the file
				} else if (stat(preInstFile, &statbuf) != 0) {
					// ERROR!
					fclose(myselfFH);
					LOGMSG(131, "Pre-install script defined by not included in the srchive\n");
			
				// Check for its permissions to be executed
				} else if ((statbuf.st_mode & S_IXUSR) == 0) {
					// ERROR!	
					fclose(myselfFH);
					LOGMSG(131, "Wrong pre-install script's permissions\n");

				// pre-install script execution
				} else if (system(preInstFile) != 0) {
					// ERROR!
					fclose(myselfFH);
					LOGMSG(131, "pre-install procedure failed\n");
				}
			}
			
			entry = NULL;
			result = ARCHIVE_OK;

			//
			// Package's files extraction....
			//
			while ((result = archive_read_next_header(tgzArch, &entry)) == ARCHIVE_OK) {
				result = archive_write_header(disk, entry);

				if (result != ARCHIVE_OK && result != ARCHIVE_WARN) {
					// ERROR!
					fclose(myselfFH);
					LOGMSG(
						131, "Unable to create '%s': %s\n", archive_entry_pathname(entry), archive_error_string(disk)
					);

				} else {
					if (result == ARCHIVE_WARN) {
						LOGMSG( 18, "WARNING! '%s': %s\n", archive_entry_pathname(entry), archive_error_string(disk));
					} else {
						LOGMSG(1, "+ %s\n", archive_entry_pathname(entry));
					}
					
					const void *data = NULL;
					size_t size = 0;
					la_int64_t offset = 0;

					//
					// Reading the file's content
					//
					while ((result = archive_read_data_block(tgzArch, &data, &size, &offset)) == ARCHIVE_OK) {
						result = archive_write_data_block(disk, data, size, offset);

						if (result != ARCHIVE_OK && result != ARCHIVE_WARN) {
							// ERROR!
							fclose(myselfFH);
							LOGMSG(
								131, "Unable to write '%s': %s\n",
								archive_entry_pathname(entry),
								archive_error_string(disk)
							);
							
						}
						
					}

					if (result != ARCHIVE_EOF) {
						// ERROR!
						fclose(myselfFH);
						LOGMSG(
							131, "Unable to read '%s': %s\n",
							archive_entry_pathname(entry),
							archive_error_string(tgzArch)
						);
					}
				}

				// Check for the whole file writing operation
				result = archive_write_finish_entry(disk);

				if (result == ARCHIVE_OK) {
					mode_t fileType = archive_entry_filetype(entry);

					if (fileType == AE_IFREG || fileType == AE_IFLNK)
						// Adding the file to the installed ones list
						g_ptr_array_add(installedFiles, g_strdup(archive_entry_pathname(entry)));
					
				} else {
					// ERROR!
					fclose(myselfFH);
					LOGMSG(
						131, "Unable to complete '%s': %s\n",
						archive_entry_pathname(entry),
						archive_error_string(disk)
					);
				}
			} // === while-loop ===

			if (result != ARCHIVE_EOF) {
				// ERROR!
				fclose(myselfFH);
				LOGMSG(131, "Unable to read archive: %s\n", archive_error_string(tgzArch));
			}


			//
			// Sytem resources closing and releasing
			//
			archive_read_close(tgzArch);
			archive_write_close(disk);
			archive_read_free(tgzArch);
			archive_write_free(disk);
			fclose(myselfFH);

			
			// Package's info file creation
			{
				FILE *repFH = fopen(pckgFilename, "w");
				if (repFH == NULL)
					// ERROR!
					LOGMSG(152, "I cannot write the \"%s\" file\n", pckgFilename);

				else {
					for (guint x = 0; x < installedFiles->len; x++) {
						const char *filename = g_ptr_array_index(installedFiles, x);
						if (fprintf(repFH, "/%s\n", filename) < 0) {
							fclose(repFH);
							LOGMSG(131, "Unable to write '%s'\n", pckgFilename);
						}
					}

					fclose(repFH);
				}
			}
						
			// Post install script execution
			if (*POSTINST != '\0') {
				struct stat statbuf;
				char        postInstFile[PATH_MAX];

				if (filesGlue("/winstall", PREINST, postInstFile) == false) {
					// ERROR!
					LOGMSG(131, "Configured path or filename is not allowed\n");

				// Check for the file
				} else if (stat(postInstFile, &statbuf) != 0) {
					// ERROR!
					LOGMSG(131, "Post-install script defined by not included in the archive\n");
			
				// Check for its permissions to be executed
				} else if ((statbuf.st_mode & S_IXUSR) == 0) {
					// ERROR!	
					LOGMSG(131, "Wrong post-install script's permissions\n");

				// pre-install script execution
				} else if (system(postInstFile) != 0) {
					// ERROR!
					LOGMSG(131, "post-install procedure failed\n");
				}
			}
			
			// installer's folder removing
			if (rm_rf(DATALOGFOLDER) < 0) 
				LOGMSG(131, "Impossible to remove the \"%s\" folder\n", DATALOGFOLDER);

			// Coming back to the original poition
			else if (chdir("-") != 0)
				// ERROR!
				LOGMSG(145, "I cannot change my position inside the Filesystem\n");
		}
	}

	return(0);
}
