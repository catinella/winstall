#-------------------------------------------------------------------------------------------------------------------------------
#                                             __        __   ___           _        _ _ 
#                                             \ \      / /  |_ _|_ __  ___| |_ __ _| | |
#                                              \ \ /\ / /____| || '_ \/ __| __/ _` | | |
#                                               \ V  V /_____| || | | \__ \ || (_| | | |
#                                                \_/\_/     |___|_| |_|___/\__\__,_|_|_|
#                                                                                       
#	
# Filename: Makefile
#
# Author: Silvano Catinella <catinella@yahoo.com>
#	
# Description:
#	This Makefile allows you to create self extracting pakages. Every one of them is composed by a binary part that manages
#	all installation process, and another component with all archived data and the pre/post-installation scripts, eventually.
#
#	+------------------+
#	| Executable code  |
#	+------------------+
#	|                  |
#	|                  |
#	| TGZ Archive data |
#	|                  |
#	|                  |
#	+------------------+
#
#	WINSTALLCONF
#	============
#	All specific data needed to build the package are collected by winstall.sh process and it shares these information
#	with the self-extractor's installation manager with an header file with all configuration values available as
#	C symbols. This file must be generated by winstall.sh script execution
#
#	This make process is called by winstall.sh script respecting the following syntax:
#		WINSTALLCONF=<file.h> PRJNAME="<string>" TGZ="<file-name> make
#
#-------------------------------------------------------------------------------------------------------------------------------
SRCs := $(shell ls *.c)
OBJs := $(SRCs:.c=.o)

INCLUDE = -I. $(shell pkg-config --cflags glib-2.0)
LIB     = $(shell pkg-config --libs glib-2.0) $(shell pkg-config --libs libarchive)



.PHONY: clean

all:			$(PRJNAME).bin

selfInstaller:	selfInstaller.o $(OBJs);
			@echo "[ LD ] $@"
			@gcc -Wall -o $@ $^ $(LIB)

%.o:			%.c
			@echo "[ CC ] $@"
			@gcc -Wall -o $@ $(INCLUDE) -c $<

%.c:			%.c.tmpl
			@echo "[SCRIPT] $@"
			@if [ -n "$(WINSTALLCONF)" ]; then                          \
				sed 's|##WINSTALLCONF##|"$(WINSTALLCONF)"|' $< > $@ ; \
			else                                                        \
				echo "ERROR! WINSTALLCONF is undefined symbol";       \
				exit 127;                                             \
			fi

$(PRJNAME).bin:	selfInstaller $(TGZ)
			@echo "[SCRIPT] $@"
			@if [ -n "$(PRJNAME)" ]; then \
				cat $^ > $@
			else                                                        \
				echo "ERROR! PRJNAME is undefined symbol";       \
				exit 127;                                             \
			fi

clean:
			@echo "[CLEAN]"
			@rm -fv selfInstaller.c *.o selfInstaller

cleanall:		clean
			@rm -fv $(PRJNAME).bin
